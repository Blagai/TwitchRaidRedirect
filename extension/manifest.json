{
    "name": "Twitch Raid Redirect",
    "author": "Blagai",
    "version": "1.0.0",
    "permissions": ["activeTab", "scripting"],
    "manifest_version": 3,
    "description": "Automatically redirects you to a different channel when a raid is detected.",
    "content_scripts": [
        {
            "matches": ["https://twitch.tv/*"],
            "js": ["content.js"]
        }

    ],
    "background": {
        "service_worker": "background.ts"
    }
}